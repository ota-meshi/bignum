{
  "name": "@bignum/babel-plugin",
  "version": "3.0.1",
  "description": "Babel plugin to replace tagged template literals with BigNum JS expressions.",
  "type": "module",
  "main": "lib/index.js",
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "require": "./lib/index.cjs",
      "default": "./lib/index.js"
    }
  },
  "files": [
    "lib"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prebuild": "npm run -s clean",
    "build": "npm run bundle",
    "bundle": "tsdown",
    "clean": "rimraf .nyc_output lib coverage",
    "test": "node --import @oxc-node/core/register ../../node_modules/mocha/bin/mocha.js \"tests/src/**/*.mts\" --reporter dot --timeout 60000",
    "cover": "c8 --reporter=lcov npm run test",
    "debug": "node --import @oxc-node/core/register ../../node_modules/mocha/bin/mocha.js \"tests/src/**/*.mts\" --reporter dot",
    "type-check": "tsc --noEmit",
    "update-snap": "node --import @oxc-node/core/register ../../node_modules/mocha/bin/mocha.js \"tests/src/**/*.mts\" --reporter dot --update"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ota-meshi/bignum.git"
  },
  "keywords": [
    "bignum",
    "bigdecimal",
    "arbitrary-precision",
    "arbitrary",
    "precision",
    "arithmetic",
    "big",
    "number",
    "decimal",
    "float",
    "biginteger",
    "bignumber",
    "bigint",
    "formula",
    "template-literal",
    "babel",
    "babel-plugin"
  ],
  "author": "Yosuke Ota",
  "funding": "https://github.com/sponsors/ota-meshi",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ota-meshi/bignum/issues"
  },
  "homepage": "https://github.com/ota-meshi/bignum/tree/main/packages/babel-plugin#readme",
  "devDependencies": {
    "@babel/core": "^7.26.7",
    "@bignum/template-light": "^2.0.0",
    "@types/babel__helper-module-imports": "^7.18.3",
    "@types/babel__helper-plugin-utils": "^7.10.3"
  },
  "dependencies": {
    "@babel/helper-module-imports": "^7.25.9",
    "@babel/helper-plugin-utils": "^7.26.5",
    "@babel/types": "^7.26.7",
    "@bignum/template-compiler": "^2.0.0"
  },
  "peerDependencies": {
    "@bignum/template": "^2.0.0"
  }
}
